generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Example {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("examples")
}

model GoogleCalendarAccount {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("google_calendar_accounts")
}

model Chat {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String        @unique @map("user_id") @db.Uuid
  title         String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  providerState ChatProvider?
  messages      Message[]

  @@map("chats")
}

model Message {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId             String    @map("chat_id") @db.Uuid
  role               String
  content            String
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  isScheduleProposal Boolean   @default(false) @map("is_schedule_proposal")
  chat               Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  schedule           Schedule?

  @@index([chatId, createdAt], map: "idx_messages_chat_created")
  @@index([chatId], map: "idx_messages_chat_id")
  @@map("messages")
}

model Schedule {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String         @map("user_id") @db.Uuid
  messageId             String?        @unique @map("message_id") @db.Uuid
  summary               String
  description           String?
  location              String?
  startDateTime         DateTime       @map("start_date_time") @db.Timestamptz(6)
  endDateTime           DateTime       @map("end_date_time") @db.Timestamptz(6)
  googleCalendarEventId String?        @map("google_calendar_event_id")
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  status                ScheduleStatus @default(PENDING)
  studyPlanId           String?        @map("study_plan_id") @db.Uuid
  message               Message?       @relation(fields: [messageId], references: [id], onUpdate: NoAction)
  studyPlan             StudyPlan?     @relation(fields: [studyPlanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([studyPlanId], map: "idx_schedules_study_plan_id")
  @@index([userId], map: "idx_schedules_user_id")
  @@map("schedules")
}

model ChatProvider {
  chatId                 String   @id @map("chat_id") @db.Uuid
  provider               String
  externalConversationId String?  @map("external_conversation_id")
  externalResponseId     String?  @map("external_response_id")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  chat                   Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("chat_providers")
}

model StudyPlan {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  title            String
  goal             String
  topics           String[]
  startDate        DateTime         @map("start_date") @db.Date
  endDate          DateTime         @map("end_date") @db.Date
  availableDays    Weekday[]        @map("available_days")
  startTime        String           @map("start_time")
  endTime          String           @map("end_time")
  difficultyLevel  DifficultyLevel  @map("difficulty_level")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  focusPreferences FocusPreferences @map("focus_preferences")
  schedules        Schedule[]

  @@index([userId], map: "idx_study_plans_user_id")
  @@map("study_plans")
}

model DeviceToken {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  token     String   @unique
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())

  @@index([userId])
}

enum ScheduleStatus {
  PENDING
  ACCEPTED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum FocusPreferences {
  DEEP_FOCUS
  BALANCED
  PODOMORO
}