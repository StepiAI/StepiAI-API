generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Example {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("examples")
}

model GoogleCalendarAccount {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("google_calendar_accounts")
}

model Chat {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String        @unique @map("user_id") @db.Uuid
  title         String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  providerState ChatProvider?
  messages      Message[]

  @@map("chats")
}

model Message {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId             String   @map("chat_id") @db.Uuid
  role               String
  content            String
  isScheduleProposal Boolean  @default(false) @map("is_schedule_proposal")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  chat               Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([chatId, createdAt], map: "idx_messages_chat_created")
  @@index([chatId], map: "idx_messages_chat_id")
  @@map("messages")
}

model ChatProvider {
  chatId                 String   @id @map("chat_id") @db.Uuid
  provider               String
  externalConversationId String?  @map("external_conversation_id")
  externalResponseId     String?  @map("external_response_id")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  chat                   Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("chat_providers")
}
