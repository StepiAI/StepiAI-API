
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Example {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("examples")
}
